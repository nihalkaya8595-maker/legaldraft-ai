# ──────────────────────────────────────────────────────────────────
#  LegalDraft AI — Variables d'environnement
#  Copiez ce fichier en ".env" et remplissez vos vraies valeurs.
#  ⚠️  Ne commitez JAMAIS le fichier .env dans Git.
# ──────────────────────────────────────────────────────────────────

# ── STRIPE ──────────────────────────────────────────────────────────
# Clés disponibles sur : https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_VOTRE_CLE_SECRETE_ICI
STRIPE_WEBHOOK_SECRET=whsec_VOTRE_SECRET_WEBHOOK_ICI

# ID du prix mensuel créé dans Dashboard Stripe → Produits → Abonnements
STRIPE_SUBSCRIPTION_PRICE_ID=price_VOTRE_PRICE_ID_ICI

# ── AUTH (JWT) ───────────────────────────────────────────────────────
# Clé secrète pour signer les tokens JWT — changez en prod !
JWT_SECRET=votre-secret-jwt-tres-long-et-aleatoire

# ── ADMIN ────────────────────────────────────────────────────────────
# Clé secrète pour accéder à GET /admin/free-doc-usage
# Envoyez via header : X-Admin-Key: <valeur>
ADMIN_KEY=votre-cle-admin-secrete

# ── SERVEUR ──────────────────────────────────────────────────────────
PORT=4242

# ── FRONTEND ─────────────────────────────────────────────────────────
# URL de votre frontend (pour CORS). En dev : http://localhost:3000
# En production : https://votre-domaine.com
FRONTEND_URL=http://localhost:3000
